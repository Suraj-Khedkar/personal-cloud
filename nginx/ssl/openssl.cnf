[req]
default_bits = 2048
prompt = no
default_md = sha256
distinguished_name = dn
req_extensions = req_ext

[dn]
CN = personal-cloud.local
O = Personal Cloud
C = IN

[req_ext]
subjectAltName = @alt_names

[alt_names]
DNS.1 = personal-cloud.local
DNS.2 = localhost
IP.1 = 127.0.0.1
IP.2 = 192.168.1.4
IP.3 = 100.94.81.46
